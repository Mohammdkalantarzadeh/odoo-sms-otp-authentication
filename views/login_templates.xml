<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="otp_login_page" name="OTP Login Page">
        <html>
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
                <title>Login with Verification Code</title>

                <link href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css" rel="stylesheet"/>

                <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css"/>

                <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>

                <link rel="stylesheet" href="/custom_otp_login/static/src/css/otp_style.css"/>
            </head>
            <body>
                <div class="otp-login-wrapper">
                    <div class="otp-card">

                        <div class="otp-card-header">
                            <div class="otp-icon-wrapper">
                                <i class="fa fa-mobile-alt"></i>
                            </div>
                            <h2>Login with Mobile Number</h2>
                            <p>A verification code will be sent to you via SMS</p>
                </div>

                        <div class="otp-card-body">

                            <div id="step1">
                                <div id="phoneError" class="otp-alert otp-alert-danger d-none">
                                    <i class="fa fa-exclamation-circle"></i>
                                    <span></span>
                                </div>

                                <div class="otp-field-group">
                                    <label for="phone">
                                        <i class="fa fa-phone"></i>
                                        Mobile Number
                                    </label>
                                    <div class="otp-input-wrapper">
                                        <input type="tel" 
                                               id="phone" 
                                               class="otp-input" 
                                               placeholder="09123456789" 
                                               maxlength="11"
                                               autocomplete="tel"/>
                                        <i class="fa fa-mobile-alt"></i>

                                    </div>
                                </div>

                                <button id="sendBtn" class="otp-btn-primary">
                                    <i class="fa fa-paper-plane"></i>
                                    <span>Send Verification Code</span>
                                </button>
                            </div>

                            <div id="step2" class="d-none">
                                <div id="otpError" class="otp-alert otp-alert-danger d-none">
                                    <i class="fa fa-exclamation-circle"></i>
                                    <span></span>
                                </div>

                                <div class="otp-field-group">
                                    <label for="code">
                                        <i class="fa fa-key"></i>
                                        Verification code sent to
                                        <strong id="phoneDisplay" style="color: #667eea;"></strong>
                                    </label>
                                    <div class="otp-input-wrapper">
                                        <input type="text" 
                                               id="code" 
                                               class="otp-input" 
                                               placeholder="------" 
                                               maxlength="6"
                                               inputmode="numeric"
                                               pattern="[0-9]*"
                                               autocomplete="one-time-code"/>
                                        <i class="fa fa-shield-alt"></i>
                                    </div>
                                </div>

                                <button id="verifyBtn" class="otp-btn-primary">
                                    <i class="fa fa-check-circle"></i>
                                    <span>Login to Account</span>
                                </button>

                                <div class="otp-timer" id="timerBox">
                                    Resend code in
                                    <span id="countdown">120</span>
                                    seconds
                                </div>

                                <button id="resendBtn" class="otp-btn-link d-none">
                                    <i class="fa fa-redo"></i>
                                    Resend Verification Code
                                </button>

                                <button id="backBtn" class="otp-btn-link">
                                    <i class="fa fa-arrow-right"></i>
                                    Change Mobile Number
                                </button>
                            </div>



                        </div>

                        <div class="otp-card-footer">
                            <p>
                                <i class="fa fa-shield-alt"></i>
                                Secure login with one-time password
                            </p>
                        </div>
                            <div class="otp-odoo-login-wrapper">
                                <button id="odooLoginBtn" class="otp-btn-odoo-login">
                                    <i class="fa fa-sign-in-alt"></i>
                                    <span>Login with Username and Password</span>
                                </button>
                            </div>

                    </div>
                </div>

                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
                <script type="text/javascript" src="/custom_otp_login/static/src/js/otp_login.js"></script>
            </body>
        </html>
    </template>


</odoo>